# No environment variables are required for the frontend.
# The API base URL is set directly in src/config.js -> apiBaseUrl.
# If you need to inject it at build time, you can do:
#
# VITE_API_BASE_URL=http://localhost:8001
#
# Then update src/config.js:
#   apiBaseUrl: import.meta.env.VITE_API_BASE_URL ?? "http://localhost:8001"
