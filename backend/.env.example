# LLM provider: openrouter | openai | gemini | ollama
LLM_PROVIDER=openrouter

# Model name for the selected provider.
# Examples:
# - OpenRouter: openai/gpt-4o-mini
# - OpenAI: gpt-4o-mini
# - Gemini: gemini-1.5-flash
# - Ollama: llama3
LLM_MODEL=

LLM_TEMPERATURE=0.2

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CA_BUNDLE=
OPENROUTER_VERIFY_SSL=true

# OpenAI
OPENAI_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Search provider: duckduckgo | tavily | serpapi
SEARCH_PROVIDER=duckduckgo

# Tavily
TAVILY_API_KEY=

# SerpAPI
SERPAPI_API_KEY=

SEARCH_RESULTS_PER_QUERY=5
MAX_SEARCH_ITERATIONS=2
